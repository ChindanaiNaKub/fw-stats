#!/usr/bin/env node
'use strict';

const http = require('http');
const { exec } = require('child_process');

const API_URL = 'https://gateway.fastwork.co/graphql';
const QUERY = `{
  categories {
    id
    title
    subcategory_groups {
      id
      title
      subcategories {
        id
        title
        minimum_price
        avg_rating
        reviews_count
      }
    }
  }
}`;

// ── helpers ──────────────────────────────────────────────────────────
// Unicode display width (East Asian Width approximation)
function displayWidth(s) {
  let w = 0;
  for (const ch of s) {
    const code = ch.codePointAt(0);
    // CJK range (Chinese, Japanese, Korean) = 2 cells
    if (code >= 0x1100 && (code <= 0x115F || code === 0x2329 || code === 0x232A ||
        code >= 0x2E80 && code <= 0xA4CF ||
        code >= 0xAC00 && code <= 0xD7A3 ||
        code >= 0xF900 && code <= 0xFAFF ||
        code >= 0xFE10 && code <= 0xFE19 ||
        code >= 0xFE30 && code <= 0xFE6F ||
        code >= 0xFF01 && code <= 0xFF60 ||
        code >= 0xFFE0 && code <= 0xFFE6)) w += 2;
    else w += 1;
  }
  return w;
}

function padToWidth(s, w) {
  const dw = displayWidth(s);
  const needed = w - dw;
  return needed > 0 ? s + ' '.repeat(needed) : s;
}

function parseArgs(argv) {
  const args = { sort: 'opportunity', top: null, format: 'table', showAll: false };
  for (let i = 2; i < argv.length; i++) {
    const a = argv[i];
    if (a === '--json')       { args.format = 'json'; continue; }
    if (a === '--csv')        { args.format = 'csv';  continue; }
    if (a === '--tsv')        { args.format = 'tsv';  continue; }
    if (a === '--sort' || a === '-s') { args.sort = argv[++i]; continue; }
    if (a === '--top' || a === '-n')  { args.top = Number(argv[++i]); continue; }
    if (a === '--all')        { args.showAll = true; continue; }
    if (a === '--help' || a === '-h') {
      console.log(`Usage: fw-stats [options]

Commands:
  serve          Start local dashboard server on port 3456

Options:
  --sort <field>   Sort by: price | opportunity (default) | ratio | reviews
  --top <N>        Show only top N results (default: 20)
  --all            Show all results (no limit)
  --json           Output JSON array
  --csv            Output CSV with headers
  --tsv            Output TSV (tab-separated, no escaping)
  -h, --help       Show this help`);
      process.exit(0);
    }
    console.error(`Unknown option: ${a}`);
    process.exit(1);
  }
  return args;
}

// ── fetch + transform ────────────────────────────────────────────────
async function fetchData() {
  let resp;
  try {
    resp = await fetch(API_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ query: QUERY }),
    });
  } catch (err) {
    console.error(`Error: ${err.message}`);
    process.exit(1);
  }
  if (!resp.ok) {
    console.error(`Error: HTTP ${resp.status} ${resp.statusText}`);
    process.exit(1);
  }
  const json = await resp.json();
  if (json.errors) {
    console.error(`Error: API returned errors:\n${JSON.stringify(json.errors, null, 2)}`);
    process.exit(1);
  }
  return json.data;
}

function flatten(data) {
  const rows = [];
  const categories = data.categories || [];
  for (const cat of categories) {
    const catTitle = cat.title || 'N/A';
    for (const group of (cat.subcategory_groups || [])) {
      for (const sub of (group.subcategories || [])) {
        const price  = sub.minimum_price ?? 0;
        const rating = sub.avg_rating    ?? 0;
        const reviews = sub.reviews_count ?? 0;
        rows.push({
          category:      catTitle,
          subcategory:   sub.title || 'N/A',
          minimum_price: price,
          avg_rating:    rating,
          reviews_count: reviews,
          opportunity_score: price * reviews * (rating / 5),
        });
      }
    }
  }
  return rows;
}

// ── sorting ──────────────────────────────────────────────────────────
const SORT_KEYS = {
  price:       'minimum_price',
  reviews:     'reviews_count',
  opportunity: 'opportunity_score',
  ratio:       'opportunity_score',
};

function sortRows(rows, key) {
  const field = SORT_KEYS[key];
  if (!field) {
    console.error(`Error: unknown sort key "${key}". Use: price, opportunity, ratio, reviews`);
    process.exit(1);
  }
  return rows.sort((a, b) => b[field] - a[field]);
}

// ── output formatters ────────────────────────────────────────────────
function printTable(rows) {
  const cols = ['Category', 'Subcategory', 'Min Price', 'Avg Rtg', 'Reviews', 'Opportunity'];
  const keys = ['category', 'subcategory', 'minimum_price', 'avg_rating', 'reviews_count', 'opportunity_score'];

  // compute display widths
  const widths = cols.map((c, i) => {
    let max = displayWidth(c);
    for (const r of rows) {
      const val = String(r[keys[i]] ?? '');
      const dw = displayWidth(val);
      if (dw > max) max = dw;
    }
    return max;
  });

  // header row
  const line = cols.map((c, i) => padToWidth(c, widths[i])).join('  ');
  console.log(line);
  // separator
  console.log(widths.map(w => '─'.repeat(w)).join('──'));

  for (const r of rows) {
    const row = keys.map((k, i) => padToWidth(String(r[k] ?? ''), widths[i])).join('  ');
    console.log(row);
  }
}

function printJson(rows) {
  console.log(JSON.stringify(rows, null, 2));
}

function printDelimited(rows, sep) {
  const cols = ['Category', 'Subcategory', 'Min Price (THB)', 'Avg Rating', 'Reviews', 'Opportunity Score'];
  const keys = ['category', 'subcategory', 'minimum_price', 'avg_rating', 'reviews_count', 'opportunity_score'];
  console.log(cols.join(sep));
  for (const r of rows) {
    console.log(keys.map(k => r[k] ?? '').join(sep));
  }
}

function printCsv(rows) { printDelimited(rows, ','); }
function printTsv(rows) { printDelimited(rows, '\t'); }

// ── serve ────────────────────────────────────────────────────────────
let dataCache = null;

async function fetchDataCached() {
  if (dataCache) return dataCache;
  const data = await fetchData();
  let rows = flatten(data);
  rows = sortRows(rows, 'opportunity');
  dataCache = rows;
  return rows;
}

function invalidateCache() {
  dataCache = null;
}

function openBrowser(url) {
  const cmd = process.platform === 'darwin' ? `open "${url}"` : `xdg-open "${url}"`;
  exec(cmd, () => {});
}

const DASHBOARD_HTML = `<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>fw-stats Dashboard</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f5f5f5; color: #333; padding: 20px; }
    h1 { margin-bottom: 12px; }
    button { padding: 8px 16px; background: #2563eb; color: #fff; border: none; border-radius: 6px; cursor: pointer; font-size: 14px; margin-bottom: 16px; }
    button:hover { background: #1d4ed8; }
    #table-container { overflow-x: auto; margin-bottom: 24px; }
    table { border-collapse: collapse; width: 100%; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 3px rgba(0,0,0,.1); }
    th, td { padding: 8px 12px; text-align: left; border-bottom: 1px solid #e5e7eb; font-size: 13px; }
    th { background: #f8fafc; font-weight: 600; position: sticky; top: 0; }
    tr:hover td { background: #f1f5f9; }
    .charts { display: flex; gap: 20px; flex-wrap: wrap; }
    .chart-box { flex: 1; min-width: 350px; background: #fff; border-radius: 8px; padding: 16px; box-shadow: 0 1px 3px rgba(0,0,0,.1); }
    .chart-box h2 { font-size: 15px; margin-bottom: 8px; }
    #status { font-size: 12px; color: #888; margin-bottom: 8px; }
  </style>
</head>
<body>
  <h1>fw-stats Dashboard</h1>
  <div id="status">Loading...</div>
  <button onclick="refreshData()">Refresh</button>
  <div id="table-container"></div>
  <div class="charts">
    <div class="chart-box"><h2>Top 15 Subcategories by Reviews</h2><canvas id="chart-reviews"></canvas></div>
    <div class="chart-box"><h2>Subcategories per Category</h2><canvas id="chart-categories"></canvas></div>
  </div>
  <script>
    let reviewsChart, categoriesChart;

    async function loadData() {
      try {
        const resp = await fetch('/api/data');
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const data = await resp.json();
        document.getElementById('status').textContent = 'Last updated: ' + new Date().toLocaleTimeString() + ' (' + data.length + ' rows)';
        renderTable(data);
        renderReviewChart(data);
        renderCategoryChart(data);
      } catch (e) {
        document.getElementById('status').textContent = 'Error: ' + e.message;
      }
    }

    function renderTable(data) {
      let html = '<table><thead><tr>';
      const cols = ['Category', 'Subcategory', 'Min Price', 'Avg Rating', 'Reviews', 'Opportunity'];
      const keys = ['category', 'subcategory', 'minimum_price', 'avg_rating', 'reviews_count', 'opportunity_score'];
      cols.forEach(c => { html += '<th>' + c + '</th>'; });
      html += '</tr></thead><tbody>';
      data.forEach(r => {
        html += '<tr>';
        keys.forEach(k => { html += '<td>' + (r[k] ?? '') + '</td>'; });
        html += '</tr>';
      });
      html += '</tbody></table>';
      document.getElementById('table-container').innerHTML = html;
    }

    function renderReviewChart(data) {
      if (reviewsChart) reviewsChart.destroy();
      const sorted = [...data].sort((a, b) => b.reviews_count - a.reviews_count).slice(0, 15);
      reviewsChart = new Chart(document.getElementById('chart-reviews'), {
        type: 'bar',
        data: {
          labels: sorted.map(r => r.subcategory),
          datasets: [{ label: 'Reviews', data: sorted.map(r => r.reviews_count), backgroundColor: '#3b82f6' }]
        },
        options: { indexAxis: 'y', plugins: { legend: { display: false } }, scales: { x: { beginAtZero: true } } }
      });
    }

    function renderCategoryChart(data) {
      if (categoriesChart) categoriesChart.destroy();
      const counts = {};
      data.forEach(r => { counts[r.category] = (counts[r.category] || 0) + 1; });
      const labels = Object.keys(counts).sort((a, b) => counts[b] - counts[a]);
      categoriesChart = new Chart(document.getElementById('chart-categories'), {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{ label: 'Subcategories', data: labels.map(l => counts[l]), backgroundColor: '#10b981' }]
        },
        options: { indexAxis: 'y', plugins: { legend: { display: false } }, scales: { x: { beginAtZero: true } } }
      });
    }

    async function refreshData() { await loadData(); }

    loadData();
  </script>
</body>
</html>`;

function serve() {
  const PORT = 3456;
  const server = http.createServer(async (req, res) => {
    if (req.url === '/api/data' && req.method === 'GET') {
      try {
        invalidateCache();
        const rows = await fetchDataCached();
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify(rows));
      } catch (e) {
        res.writeHead(500, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ error: e.message }));
      }
    } else {
      res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
      res.end(DASHBOARD_HTML);
    }
  });
  server.listen(PORT, () => {
    const url = `http://localhost:${PORT}`;
    console.log(`fw-stats dashboard running at ${url}`);
    openBrowser(url);
  });
}

// ── main ─────────────────────────────────────────────────────────────
async function main() {
  const args = parseArgs(process.argv);
  const data = await fetchData();
  let rows = flatten(data);

  // default to top 20 unless --all or explicit --top
  if (!args.showAll && args.top == null) args.top = 20;

  rows = sortRows(rows, args.sort);
  if (args.top != null) rows = rows.slice(0, args.top);

  const printers = { table: printTable, json: printJson, csv: printCsv, tsv: printTsv };
  (printers[args.format] || printTable)(rows);
}

if (process.argv[2] === 'serve') {
  serve();
} else {
  main();
}
